algoritmo "ALUNO_aprovado_reprovado_recuperçao"
var

   media,nota1,nota2: real

inicio

      Escreval ("---------------------------------------------------------")
      Escreval ("-----------ITB BRASÍLIO FLORES DE AZEVEDO----------------")
      Escreval ("---------------------------------------------------------")
      
      Escreva ("PRIMEIRA NOTA: ")
      Leia (Nota1)

      Escreva ("SEGUNDA NOTA: ")
      Leia (Nota2)
      
      Media <- (nota1+nota2) / 2
      
     Escreval ("----------------------------------------------------")
     Escreval ("-----------STATUS DE APROVAÇĂO DO ALUNO-------------")
     Escreval ("----------------------------------------------------")
     Escreval ("Média do aluno:",media)
      
      Se (Media >= 6) entao
         Escreval ("Situaçăo: Parabéns! Vocę foi aprovado.")
      senao
           Se (media >= 5) e (media < 6) entao
              Escreval ("Situaçăo: Aluno em recuperaçăo.")
           senao
                Escreval ("Situaçăo: Infelizmente,vocę foi reprovado.")
           FimSe
      Fimse

fimalgoritmo