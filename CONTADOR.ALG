Algoritmo "contador"

Var

   x,n,s: inteiro

Inicio

      x <- 0

      Escreva ("Até que número vocę deseja contar? ")
      Leia (n)
      
      Escreva ("Qual o número do salto? ")
      Leia (s)
      
      Enquanto (x <= n) faca
               escreval (x)
               x <- x + s
      FimEnquanto
      Escreval ("Terminei de contar")


Fimalgoritmo