algoritmo "em que ano voce nasceu?"
var
idade: inteiro
anoatual: inteiro
anonascimento: inteiro
inicio
Escreva ("Informe o ano atual: ")
leia(anoatual)
Escreva ("Quantos anos vocę tem? ")
leia (idade)
anonascimento <- anoatual-idade
Escreva ("Com base nessas informaçőes vocę nasceu em:",anonascimento)
fimalgoritmo