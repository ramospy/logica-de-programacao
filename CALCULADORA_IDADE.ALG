algoritmo "calculadora_idade"
var

   idade,ano_nascimento,ano_atual: inteiro

inicio

   Escreva ("Em que ano estamos?")
   Leia(ano_atual)

   Escreva("Em que ano vocę nasceu?")
   Leia (ano_nascimento)

   Idade <- (ano_atual)-(ano_nascimento)
   Escreva ("Vocę tem",idade," anos")
   
fimalgoritmo